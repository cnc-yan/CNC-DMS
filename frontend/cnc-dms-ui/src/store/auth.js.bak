import { defineStore } from 'pinia'
import { ref, computed } from 'vue'
import { login as loginApi, getCurrentUser } from '@/api/auth'

export const useAuthStore = defineStore('auth', () => {
  // --- state ---
  const token = ref(localStorage.getItem('token') || '')
  const userid = ref('')    // 当前登录的用户ID（登录标识）
  const username = ref('')  // 用于显示的用户名

  // --- getters ---
  const isAuthenticated = computed(() => !!token.value)

  // --- actions ---
  async function login(useridInput, passwordInput) {
    const res = await loginApi(useridInput, passwordInput)
    if (res.success) {
      token.value = res.token
      localStorage.setItem('token', res.token)
      return true
    }
    return false
  }

  async function fetchCurrentUser() {
    if (!token.value) return
    try {
      const data = await getCurrentUser()
      // 后端返回可能是 { userid, userName, ... }
      userid.value = data.userid || data.username || ''
      username.value = data.userName || data.userid || data.username || ''
    } catch {
      // token invalid — force logout
      logout()
    }
  }

  function logout() {
    token.value = ''
    userid.value = ''
    username.value = ''
    localStorage.removeItem('token')
  }

  return {
    token,
    userid,
    username,
    isAuthenticated,
    login,
    fetchCurrentUser,
    logout,
  }
})
