# ======================================================
# 环境变量模板 — 复制为 .env.development.local 使用
# 严禁在此文件写入真实密钥/地址
# ======================================================

# API 基础路径（前端统一使用 /api，由 Nginx/K8s 反向代理）
VITE_API_BASE_URL=/api

# 部署基础路径（默认 /，子路径部署如 /dms/ 需加前后斜杠）
VITE_BASE=/

# 应用标题（会出现在页面标题 & 登录/主页标题栏）
VITE_APP_TITLE=CNC寮管理システム

# ===== 仅开发环境有效 =====
# Vite Dev Server 代理目标（后端地址）
VITE_PROXY_TARGET=http://localhost:8080
